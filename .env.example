# ZEA Platform Environment Variables Example
# Copy this file to .env and fill in the actual values.
# SECURITY: Never share your actual .env file or commit it to version control.

# Private Key for Deployment and Admin Operations (Must be 64 characters hex)
PRIVATE_KEY=0x_YOUR_PRIVATE_KEY_HERE

# RPC Endpoints (Get these from Alchemy, Infura, or your preferred provider)
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
ARBITRUM_SEPOLIA_RPC_URL=https://arb-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# API Keys for Verification and Analytics
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY
ARBISCAN_API_KEY=YOUR_ARBISCAN_API_KEY
ALCHEMY_API_KEY=YOUR_ALCHEMY_API_KEY

# Optional: Gas Reporting and Market Data
REPORT_GAS=true
COINMARKETCAP_API_KEY=YOUR_COINMARKETCAP_API_KEY

# App Configuration
# Note: Next.js handles NODE_ENV automatically during build (production) and dev (development).
# Do NOT set NODE_ENV manually in this file to avoid build conflicts.
