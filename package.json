{
  "name": "zwallet",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "typecheck": "pnpm -r --if-present run typecheck",
    "lint": "pnpm -r --if-present run lint",
    "check:circular": "madge --circular --extensions ts apps/api/src services/wallet-engine/src services/swap-engine/src services/indexer/src packages/crypto-core/src packages/chain-adapters/src packages/shared-types/src",
    "setup:auto": "node scripts/run-installer.mjs",
    "generate:releases": "node scripts/generate-releases.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.26.0",
    "@types/cookie": "^1.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.15.3",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "eslint": "^9.26.0",
    "madge": "^8.0.0",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "bullmq": "^5.76.8",
    "cookie": "^1.1.1",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "0.27.7",
      "react": "18.3.1",
      "react-dom": "18.3.1"
    }
  }
}
