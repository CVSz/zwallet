      "default": "./dist/walletEngine.js"
    }
  },
  "dependencies": {
    "@zwallet/rpc": "workspace:*",
    "@zwallet/shared-types": "workspace:*",
    "ethers": "^6.15.0",
    "viem": "^2.48.11"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts"
